<Window x:Class="PipeSystemTransfer.UI.Views.ExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Xuất Hệ Thống Ống → JSON"
        Width="520" Height="340"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">


    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Xuất hệ thống ống sang JSON"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,6,0" Padding="4" VerticalContentAlignment="Center"
                     IsReadOnly="True" Background="#F5F5F5"/>
            <Button Grid.Column="1" Content="Chọn file..." Width="90"
                    Command="{Binding BrowseCommand}" Padding="4,6"/>
        </Grid>

        <Border Grid.Row="2" Background="#F0F4FF" BorderBrush="#BBCFEE" BorderThickness="1" CornerRadius="4" Padding="10">
            <TextBlock Text="{Binding SummaryText}" TextWrapping="Wrap"
                       FontSize="13" VerticalAlignment="Center"/>
        </Border>

        <StackPanel Grid.Row="3" Margin="0,8,0,0">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="{Binding ProgressText}" FontSize="11" Foreground="#1976D2" Margin="0,0,0,4"/>
            <ProgressBar Value="{Binding ProgressValue}" Maximum="100" Height="12"/>
        </StackPanel>

        <ScrollViewer Grid.Row="4" MaxHeight="80" VerticalScrollBarVisibility="Auto" Margin="0,6,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#555" FontSize="12" TextWrapping="Wrap"/>
        </ScrollViewer>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Xuất JSON" Width="110" Margin="0,0,8,0"
                    Command="{Binding ExportCommand}"
                    Background="#1976D2" Foreground="White" Padding="8,6"/>
            <Button Content="Đóng" Width="80" IsCancel="True" Padding="8,6"/>
        </StackPanel>
    </Grid>
</Window>
